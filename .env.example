# Copy to .env and fill in values before running locally
PORT=8080
DB_PATH=./insighta.db

# GitHub OAuth App credentials
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# For web browser flow: https://yourdomain.com/auth/github/callback
# For CLI flow: http://localhost:<port>/callback  (CLI sets this dynamically)
GITHUB_REDIRECT_URI=

# Must be at least 32 random characters
JWT_SECRET=

# Optional: override default external API base URLs
# GENDERIZE_API=https://api.genderize.io
# AGIFY_API=https://api.agify.io
# NATIONALIZE_API=https://api.nationalize.io
